```gitignore
# Compiled and build artifacts
*.class
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
target/
.m2/
.gradle/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Database
*.sql.bak
*.db.bak

# Maven specific
target/
*.jar
*.war
*.ear

# Build directories
build/
dist/
out/
```